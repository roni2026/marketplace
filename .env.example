# Supabase project credentials (see https://supabase.com/dashboard/project/_/settings/api)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Cloudinary (unsigned browser uploads)
# Cloud: iok4ild8
# Create an UNSIGNED upload preset: Dashboard → Settings → Upload → Upload presets
VITE_CLOUDINARY_CLOUD_NAME=iok4ild8
VITE_CLOUDINARY_API_KEY=477828215824789
VITE_CLOUDINARY_UPLOAD_PRESET=bazarbd_unsigned
# VITE_CLOUDINARY_FOLDER=bazarbd
# NEVER put CLOUDINARY_API_SECRET in any VITE_* variable (browser-visible).

# Emergency admin access (comma-separated auth user UUIDs from Supabase → Authentication → Users)
# Use this if /admin shows Access Denied even after granting super_admin in SQL.
VITE_ADMIN_USER_IDS=
# Optional: VITE_ADMIN_EMAILS=you@example.com
