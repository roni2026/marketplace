# Supabase project credentials (see https://supabase.com/dashboard/project/_/settings/api)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Cloudinary (unsigned browser uploads) — cloud name iok4ild8
# Create an UNSIGNED upload preset in Cloudinary Dashboard → Settings → Upload
VITE_CLOUDINARY_CLOUD_NAME=iok4ild8
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name
# Optional public API key (never put the API secret in Vite env)
# VITE_CLOUDINARY_API_KEY=
# VITE_CLOUDINARY_FOLDER=bazarbd
